# ─── GitHub OAuth ───────────────────────────────────────────────────────────
# Create an OAuth app at github.com/settings/developers
# Callback URL: http://localhost:3000/auth/callback

VITE_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── App ────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────────
# Provisioned automatically by Vercel Postgres (Neon)
# Run `vercel env pull .env.local` to get these after linking the project

POSTGRES_URL=your_postgres_url
DATABASE_URL=your_database_url

# ─── Jira OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth 2.0 (3LO) app at developer.atlassian.com/console/myapps
# Callback URLs:
#   http://localhost:3000/auth/jira/callback
#   https://your-app.vercel.app/auth/jira/callback
# Permissions: read:jira-work, read:jira-user
# offline_access is requested at runtime (not configured in the app dashboard)

JIRA_CLIENT_ID=your_jira_client_id
JIRA_CLIENT_SECRET=your_jira_client_secret

# ─── Jira API Token (scripts only) ──────────────────────────────────────────
# Used by scripts/jira/* seed scripts — not needed to run the app
# Generate at id.atlassian.com/manage-profile/security/api-tokens

JIRA_EMAIL=your_atlassian_email
JIRA_SITE=your-site.atlassian.net
JIRA_API_TOKEN=your_api_token
